---
// src/components/PublicationCard.astro
import type { CollectionEntry } from 'astro:content';

interface Props {
  publication: CollectionEntry<'publications'>;
}

const { publication } = Astro.props;
const p = publication.data;

import { getCollection } from 'astro:content';
const membersData = await getCollection('members');
const labMembers = membersData.map(m => m.data.name);

const typeLabel: Record<string, string> = {
  conference:     'Conference',
  journal:        'Journal',
  preprint:       'Preprint',
  workshop:       'Workshop',
  'book-chapter': 'Book Chapter',
};
---

<article class="group border-t border-surface-border pt-5 pb-1">

  <!-- Meta row: type · year · optional award -->
  <div class="flex items-center gap-3 mb-2 flex-wrap">
    <span class="label">{typeLabel[p.type] ?? p.type}</span>
    <span class="text-surface-divider text-xs">·</span>
    <time datetime={String(p.year)} class="text-xs text-ink-faint tabular-nums">{p.year}</time>
    {p.award && (
      <>
        <span class="text-surface-divider text-xs">·</span>
        <span class="text-xs text-ink-muted italic">{p.award}</span>
      </>
    )}
    
  </div>

  <!-- Title -->
  <h3 class="font-display text-[0.95rem] font-bold text-ink leading-snug mb-1.5 group-hover:text-accent-blue transition-colors">
    {p.url
      ? <a href={p.url} target="_blank" rel="noopener noreferrer">{p.title}</a>
      : p.title
    }
  </h3>

  <!-- Authors — lab members in bold -->
  <p class="text-sm text-ink-muted mb-1">
    {p.authors.map((author: string, i: number) => (
      <>
        {labMembers.includes(author)
          ? <strong class="font-semibold text-ink">{author}</strong>
          : <span>{author}</span>
        }
        {i < p.authors.length - 1 && <span class="text-ink-faint">, </span>}
      </>
    ))}
  </p>

  <!-- Venue -->
  <p class="text-sm text-ink-subtle italic mb-3">{p.venue}</p>

  <!-- Links -->
  <div class="flex flex-wrap items-center gap-4">
    {p.pdfUrl && (
      <a href={p.pdfUrl} target="_blank" rel="noopener noreferrer"
         class="text-xs text-accent-blue hover:text-accent-hover transition-colors">
        PDF ↗
      </a>
    )}
    {p.url && !p.pdfUrl && (
      <a href={p.url} target="_blank" rel="noopener noreferrer"
         class="text-xs text-accent-blue hover:text-accent-hover transition-colors">
        Paper ↗
      </a>
    )}
    {p.codeUrl && (
      <a href={p.codeUrl} target="_blank" rel="noopener noreferrer"
         class="text-xs text-ink-muted hover:text-ink transition-colors">
        Code ↗
      </a>
    )}
    {p.arxivId && (
      <a href={`https://arxiv.org/abs/${p.arxivId}`} target="_blank" rel="noopener noreferrer"
         class="text-xs text-ink-muted hover:text-ink transition-colors font-mono">
        arXiv:{p.arxivId}
      </a>
    )}
    {p.projectUrl && (
      <a href={p.projectUrl} target="_blank" rel="noopener noreferrer"
         class="text-xs text-ink-muted hover:text-ink transition-colors">
        Project ↗
      </a>
    )}
    {p.doi && (
      <a href={`https://doi.org/${p.doi}`} target="_blank" rel="noopener noreferrer"
        class="text-xs text-ink-muted hover:text-ink transition-colors font-mono">
        DOI:{p.doi}
      </a>
    )}
    {p.tags.length > 0 && (
  <div class="flex flex-wrap gap-1.5 mt-2">
    {p.tags.map((tag: string) => (
      <span class="text-xs text-ink-faint bg-surface-muted border border-surface-border rounded px-2 py-0.5">
        {tag}
      </span>
    ))}
  </div>
)}
  </div>
</article>
